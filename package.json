{
  "name": "angular-in-viewport",
  "version": "1.0.10",
  "scripts": {
    "ng": "ng",
    "build": "npm-run-all -s clean:build build:prod",
    "start": "npm-run-all -s clean:build build:dev watch:demo",
    "watch": "npm-run-all -s clean:build -p watch:lib watch:demo",
    "build:prod": "ng build @talentia/angular-in-viewport --configuration production",
    "build:dev": "ng build @talentia/angular-in-viewport --configuration development",
    "watch:lib": "ng build @talentia/angular-in-viewport --configuration development --watch",
    "watch:demo": "wait-on dist/angular-in-viewport/package.json && ng serve demo",
    "demo:dev": "ng build demo --configuration development",
    "demo:prod": "ng build demo --configuration production",
    "clean:build": "rimraf dist .angular",
    "clean:modules": "rimraf node_modules",
    "clean:all": "npm-run-all -p clean:build clean:modules",
    "lint": "ng lint",
    "lint:lib": "ng lint @talentia/angular-in-viewport",
    "lint:app": "ng lint demo",
    "lint:lib-fix": "ng lint @talentia/angular-in-viewport --fix",
    "lint:app-fix": "ng lint demo --fix",
    "madge:lib": "madge --circular --ts-config ./projects/angular-in-viewport/tsconfig.lib.prod.json --extensions ts ./projects/angular-in-viewport/src/",
    "madge:demo": "madge --circular --ts-config ./projects/demo/tsconfig.app.json --extensions ts ./projects/demo/src/",
    "update-browserslist": "npx update-browserslist-db@latest"
  },
  "dependencies": {
    "@angular/animations": "20.3.18",
    "@angular/common": "20.3.18",
    "@angular/compiler": "20.3.18",
    "@angular/core": "20.3.18",
    "@angular/forms": "20.3.18",
    "@angular/platform-browser": "20.3.18",
    "@angular/platform-browser-dynamic": "20.3.18",
    "@angular/router": "20.3.18",
    "rxjs": "7.8.1",
    "tslib": "2.6.2",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular/build": "20.3.21",
    "@angular/cli": "20.3.21",
    "@angular/compiler-cli": "20.3.18",
    "angular-eslint": "20.7.0",
    "eslint": "9.39.1",
    "ng-packagr": "20.3.2",
    "npm-run-all": "4.1.5",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "wait-on": "9.0.1"
  }
}
